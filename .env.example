# Brand configuration for this gym website template.
#
# To reuse this codebase for a different gym: copy this file to ".env",
# fill in that gym's details below, drop their logo/photos into public/
# (see README.md), and run `npm run build`. Nothing else in the code
# needs to change per client.
#
# All variables must be prefixed with VITE_ to be readable by the app
# (this is a Vite requirement, not optional). Every variable below is
# required — index.html reads some of these directly and the build will
# fail if one is missing.

# --- Brand identity ---
VITE_BRAND_NAME="Conquest Fitness Centre"
VITE_BRAND_SHORT="Conquest Fitness"
# City shown in page copy/titles, e.g. "Join us in Abu Dhabi" or "Gym in Abu Dhabi".
VITE_CITY="Abu Dhabi"

# --- Contact details ---
VITE_PHONE="+971 58 156 0114"
VITE_PHONE_ALT="+971 2 626 0762"
VITE_EMAIL="info@conquestfitness.ae"

# --- Address (shown as 3 lines on the Contact page and footer) ---
VITE_ADDRESS_LINE1="905 Al Falah Street"
VITE_ADDRESS_LINE2="Al Danah (Zone 1), Abu Dhabi"
VITE_ADDRESS_LINE3="United Arab Emirates"

# --- Opening hours ---
VITE_HOURS_WEEKDAY_DAYS="Monday - Friday"
VITE_HOURS_WEEKDAY_TIME="6:00 AM - 10:00 PM"
VITE_HOURS_WEEKEND_DAYS="Saturday - Sunday"
VITE_HOURS_WEEKEND_TIME="8:00 AM - 8:00 PM"

# --- Social links (use "#" for any not yet available) ---
VITE_SOCIAL_FACEBOOK="#"
VITE_SOCIAL_INSTAGRAM="#"
VITE_SOCIAL_TWITTER="#"

# --- Google Maps ---
# Optional: paste the gym's verified "Share > Embed" Google Maps link here.
# If left blank, a map is generated automatically from the brand name and
# address above (no API key needed either way).
VITE_MAP_LINK="https://www.google.com/maps/place/Conquest+Fitness+Centre"

# --- Site / SEO ---
# Full deployed URL, no trailing slash. Used for canonical link + social
# preview (Open Graph/Twitter) tags.
VITE_SITE_URL="https://project.justinjohnson.de"
VITE_SITE_TITLE="Conquest Fitness Centre | Gym in Abu Dhabi"
VITE_META_DESCRIPTION="Conquest Fitness Centre is a modern gym in Al Danah, Abu Dhabi offering personal training, strength and cardio programs, group fitness classes, and weight management support."

# --- "Our Trainers" section design (optional, defaults to "cards") ---
# cards = individual trainer photo/name/role cards (src/data/team.js)
# photo = a single team photo instead (public/OurTeam.png)
VITE_TEAM_LAYOUT="cards"

# --- Logo (optional, defaults to "/Logo.png") ---
# Path to this brand's logo file in public/. Store multiple gyms' logos
# side by side (e.g. public/Logo-IronPeak.png) and point this at the one
# to use for this deployment. Should be a black icon on a transparent
# background — it's inverted to white via CSS for the dark theme.
VITE_LOGO_PATH="/Logo.png"
